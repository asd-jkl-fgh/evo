# ========== 飞书自建应用（必填） ==========
# 在 https://open.feishu.cn/app 创建应用后拿到
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# ========== 飞书多维表格（必填） ==========
# 多维表格 URL: https://xxx.feishu.cn/base/【TOKEN】?table=【TABLE_ID】
FEISHU_BITABLE_TOKEN=your_bitable_app_token
FEISHU_TABLE_ID=tblxxxxxxxxx

# ========== 飞书群 Webhook（可选，填了会推群消息） ==========
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-key
